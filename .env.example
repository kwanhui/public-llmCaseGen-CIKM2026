# LLM provider configuration
# Set LLM_PROVIDER to "openai" or "anthropic" (Vercel AI SDK).
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# Optional model overrides (defaults: gpt-4o-mini for OpenAI,
# claude-haiku-4-5-20251001 for Anthropic).
LLM_GENERATION_MODEL=

# Retrieval. "embedding" (default) runs dense retrieval over the curated
# discipline corpus; "prompt-pack" disables retrieval (pack-only grounding).
# Embeddings always use OpenAI text-embedding-3-small, so OPENAI_API_KEY is
# required for retrieval even when LLM_PROVIDER=anthropic.
# Build the committed vector store once with: pnpm embed-corpus
RETRIEVAL_PROVIDER=embedding
EMBEDDING_MODEL=text-embedding-3-small
RETRIEVAL_TOP_K=5
# Minimum cosine similarity for a corpus passage to be eligible for grounding.
RETRIEVAL_MIN_SCORE=0.25

# Pseudonymisation salt for HMAC-SHA256 hashing of student-view fingerprints.
# Generate 32 bytes of randomness, e.g. `openssl rand -hex 32`.
PSEUDONYM_SALT=replace-with-32-bytes-of-randomness

# Vercel Postgres (Neon). Pulled automatically with `vercel env pull`.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Auth.js v5 — instructor sign-in via Credentials provider.
# AUTH_SECRET: generate with `openssl rand -hex 32`
# AUTH_URL: the public origin of the deployment (no trailing slash)
AUTH_SECRET=
AUTH_URL=https://caseforge.vercel.app

# Single-instructor demo credentials (Auth.js Credentials provider).
# ADMIN_EMAIL is what the instructor types in the email field; defaults to "admin".
# ADMIN_PASSWORD_HASH is a bcrypt hash. Generate via:
#   pnpm change-admin-password
# That script prompts for a plaintext password, hashes
# it locally, and pushes the hash to Vercel via `vercel env add` (never echoed).
ADMIN_EMAIL=admin
ADMIN_PASSWORD_HASH=
