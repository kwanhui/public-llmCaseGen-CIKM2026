{
  "name": "caseforge",
  "version": "0.1.0",
  "private": true,
  "description": "CaseForge — faculty-facing browser-based authoring tool that drafts personalised professional case studies via a four-stage RAG+LLM pipeline. CIKM 2026 Demo Track companion artifact.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,yaml,yml,json}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "embed-corpus": "tsx scripts/embed-corpus.ts",
    "retrieval-ablation": "tsx scripts/retrieval-ablation.ts",
    "grounding-report": "tsx scripts/grounding-report.ts",
    "change-admin-password": "tsx scripts/change-admin-password.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@auth/drizzle-adapter": "^1.11.2",
    "@hookform/resolvers": "^5.2.2",
    "@vercel/postgres": "^0.10.0",
    "ai": "^4.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^0.460.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^9.0.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
